{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ir-dsl.org/schemas/canvas.json",
  "title": "IRCanvas",
  "type": "object",
  "properties": {
    "width": {
      "oneOf": [{ "type": "number" }, { "type": "string", "enum": ["auto"] }]
    },
    "height": {
      "oneOf": [{ "type": "number" }, { "type": "string", "enum": ["auto"] }]
    },
    "platform": {
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "web",
            "ios_native",
            "android_native",
            "flutter",
            "instagram_feed",
            "instagram_story",
            "instagram_reel",
            "tiktok",
            "youtube_thumbnail",
            "youtube_shorts",
            "linkedin",
            "twitter_post",
            "pinterest",
            "print_a4",
            "print_a3",
            "print_a5",
            "print_letter",
            "print_tabloid",
            "billboard_horizontal",
            "billboard_vertical",
            "rollup_banner",
            "xbanner",
            "packaging_box",
            "packaging_pouch",
            "packaging_label",
            "presentation_16_9",
            "presentation_4_3"
          ]
        },
        {
          "type": "object",
          "properties": {
            "type": { "type": "string", "enum": ["custom"] },
            "width": { "type": "number" },
            "height": { "type": "number" },
            "unit": { "type": "string" }
          },
          "required": ["type", "width", "height", "unit"],
          "additionalProperties": false
        }
      ]
    },
    "fps": { "type": "number" },
    "duration_ms": { "type": "number" },
    "sample_rate": { "type": "number" },
    "unit": { "type": "string", "enum": ["px", "mm", "cm", "in", "pt"] },
    "dpi": { "type": "number" },
    "color_space": { "type": "string", "enum": ["sRGB", "CMYK", "P3", "Rec2020"] }
  },
  "required": ["width", "height", "platform"],
  "additionalProperties": false
}
