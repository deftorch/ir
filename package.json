{
  "name": "ir-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Monorepo for IR Visual Design & Multimedia DSL",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "npm test --workspaces --if-present",
    "build": "npm run build -w ir-schema && npm run build -w ir-compiler && npm run build -w ir-renderer-web",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^1.0.0"
  }
}
